// WorshipHQ — multi-tenant church management schema.
// Every record is scoped to a Church (tenant) and optionally a Branch.
// The app currently runs in stub mode on seeded demo data (src/lib/demo/data.ts);
// this schema mirrors those shapes so wiring a real PostgreSQL database is a
// drop-in: set DATABASE_URL, run `npx prisma migrate dev`, then swap demo reads
// for Prisma queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Platform config (singleton — one row, id="default") ──
model PlatformConfig {
  id       String @id @default("default")
  currency String @default("GHS")
  currencySymbol String @default("₵")
  // Plan prices stored as JSON: { free: { monthly: 0, yearly: 0 }, starter: { monthly: 99, yearly: 990 }, ... }
  planPrices Json?
  updatedAt DateTime @updatedAt
}

// ── Tenancy ───────────────────────────────────────────────
model Church {
  id           String   @id @default(cuid())
  slug         String   @unique
  isDemo       Boolean  @default(false)
  suspended    Boolean  @default(false)
  smsCredits       Int     @default(50) // prepaid SMS units (50 free on signup)
  smsWelcomeMember Boolean @default(true) // SMS a welcome to members who self-register
  memberPrefix String? // member ID prefix, e.g. "GBC" (derived from name if unset)
  memberSeq    Int     @default(0) // last issued member number
  name         String
  denomination String?
  city         String?
  country      String   @default("Ghana")
  address      String?
  accentColor  String   @default("#6D5EF8")
  logoUrl      String?

  // SMS Sender ID approval system
  smsSenderId           String?
  smsSenderIdStatus     String   @default("pending")
  smsSenderIdRequestedAt DateTime?
  smsSenderIdApprovedAt DateTime?
  smsSenderIdApprovedBy String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // JSON config: which fields to show on the public join form
  registrationFields Json?

  // Per-church overrides for built-in role permissions (JSON map of role → sections[])
  rolePermissions Json?

  // JSON config: visitor form fields (simpler than full registration)
  visitorFormFields Json?

  // JSON config: children & teens registration forms
  childrenFormFields Json?
  teensFormFields    Json?

  // Customizable SMS receipt templates (use {name}, {amount}, {church} placeholders)
  titheReceiptTemplate   String?
  harvestReceiptTemplate String?

  featuredLeaderCount Int @default(6) // number of leaders shown on dashboard

  branches      Branch[]
  users         User[]
  customRoles   CustomRole[]
  people        Person[]
  departments   Department[]
  households     Household[]
  groups        Group[]
  funds         Fund[]
  gifts         Gift[]
  pledges       Pledge[]
  campaigns     Campaign[]
  events        Event[]
  attendance    AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  assignments   VolunteerAssignment[]
  communications Communication[]
  automations   Automation[]
  reminders     Reminder[]
  transactions  Transaction[]
  smsTransactions SmsTransaction[]
  harvests      Harvest[]
  harvestContributions HarvestContribution[]
  subscription  Subscription?
  visitors      Visitor[]
  followUps     FollowUp[]
  prayerRequests PrayerRequest[]
  notices        ChurchNotice[]
  welfareRecords WelfareRecord[]
  auditLogs      AuditLog[]
  sermons        Sermon[]
  assets         Asset[]
  expenses       Expense[]
  facilities     Facility[]
  bookings       Booking[]
  devotionals    Devotional[]
  testimonies    Testimony[]
  counselingSessions CounselingSession[]
  budgets        Budget[]
  budgetItems    BudgetItem[]
  volunteerRosters VolunteerRoster[]
  volunteerSlots  VolunteerSlot[]
}

model Branch {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  city      String?
  isHQ      Boolean  @default(false)
  createdAt DateTime @default(now())

  people      Person[]
  events      Event[]
  attendance  AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  gifts       Gift[]
  users       User[]

  @@index([churchId])
}

// ── Auth / RBAC ───────────────────────────────────────────
enum Role {
  Owner
  Admin
  Pastor
  Finance
  Media
  Leader
  Volunteer
}

// ── Departments ──────────────────────────────────────────
model Department {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())

  people    Person[] @relation("PrimaryDepartment") // legacy single-department link
  members   Person[] @relation("PersonDepartments") // many-to-many membership
  positions DepartmentPosition[]

  @@unique([churchId, name])
  @@index([churchId])
}

// A person's named position within a department (Head, Assistant, Secretary, etc.)
// One person can hold positions in multiple departments.
model DepartmentPosition {
  id           String     @id @default(cuid())
  churchId     String
  personId     String
  person       Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  position     String     // e.g. Head, Assistant Head, Secretary, Treasurer, Member
  createdAt    DateTime   @default(now())

  @@unique([personId, departmentId, position])
  @@index([churchId])
  @@index([personId])
}

// Admin-defined role with custom section access + delete permission.
model CustomRole {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  sections  String[] // module keys this role can see
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())

  users User[]

  @@unique([churchId, name])
  @@index([churchId])
}

model User {
  id           String   @id @default(cuid())
  churchId     String
  church       Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(Volunteer)
  customRoleId String?
  customRole   CustomRole? @relation(fields: [customRoleId], references: [id])
  photoUrl      String?  // staff profile picture (data URL)
  phone         String?
  phoneVerified Boolean  @default(false)
  // A User (logs in) may be linked to a Person (a congregant record).
  personId     String?  @unique
  person       Person?  @relation(fields: [personId], references: [id])
  createdAt    DateTime @default(now())
  assignedFollowUps FollowUp[]
  auditLogs         AuditLog[]
  counselingSessions CounselingSession[]

  @@index([churchId])
}

// ── People ────────────────────────────────────────────────
enum PersonStatus {
  active
  visitor
  inactive
}

model Person {
  id          String       @id @default(cuid())
  churchId    String
  church      Church       @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id])
  memberId    String? // human-friendly ID, e.g. GBC-0001 (unique per church)
  firstName   String
  lastName    String
  otherNames  String?
  email       String?
  phone       String?
  status      PersonStatus @default(active)
  location    String?
  photoUrl    String?
  birthday    String? // MM-DD
  anniversary String? // MM-DD
  joinedAt    DateTime     @default(now())
  notes       String?
  customFields Json?

  // ── Leadership ──
  leaderTitle    String?   // e.g. Head Pastor, Associate Pastor, Shepherd, Elder
  featured       Boolean   @default(false) // Featured on dashboard (e.g. Head Pastor)
  leaderSortOrder Int      @default(0)     // Admin-defined display order (lower = first)

  // ── Rich profile fields (from registration / admin entry) ──
  gender         String?   // Male, Female
  title          String?   // e.g. Rev., Deaconess, Elder
  dateOfBirth    DateTime? // full DOB
  occupation     String?
  employer       String?
  previousChurch String?
  dateOfMembership DateTime?
  placeOfBirth   String?
  nationality    String?
  country        String?
  region         String?
  district       String?
  town           String?
  nationalId     String?
  houseAddress   String?
  homeTown       String?
  workPhone      String?
  postalAddress  String?
  homePhone      String?
  specialInterest String?
  maritalStatus  String?  // Single, Married, Divorced, Widowed
  baptized       Boolean? // Has been baptised?

  // ── Age group & guardian (children/teens forms) ──
  ageGroup       String?  // "adult", "teen", "child"
  parentId       String?
  parent         Person?  @relation("ParentChild", fields: [parentId], references: [id], onDelete: SetNull)
  children       Person[] @relation("ParentChild")
  guardianName   String?
  guardianPhone  String?
  school         String?
  grade          String?

  // ── Emergency contact ──
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?
  emergencyEmail   String?
  emergencyAddress String?

  // ── Department ──
  // departmentId is the legacy single department (kept for back-compat / data
  // safety). `departments` is the new many-to-many (a member can be in several).
  departmentId String?
  department   Department? @relation("PrimaryDepartment", fields: [departmentId], references: [id])
  departments  Department[] @relation("PersonDepartments")

  positions   DepartmentPosition[]

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])
  groups      Group[]    @relation("GroupMembers")
  leaderOf    Group[]    @relation("GroupLeader")
  tags        Tag[]      @relation("PersonTags")
  gifts       Gift[]
  harvestContributions HarvestContribution[]
  attendance  AttendanceRecord[]
  followUps      FollowUp[]
  prayerRequests PrayerRequest[]
  welfareRecords WelfareRecord[]
  biometrics     BiometricCredential[]
  testimonies    Testimony[]
  counselingSessions CounselingSession[]
  volunteerSlots VolunteerSlot[]
  user           User?

  @@unique([churchId, memberId])
  @@index([churchId])
  @@index([branchId])
  @@index([departmentId])
  @@index([parentId])
}

model Household {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  members  Person[]

  @@index([churchId])
}

model Group {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  type        String   @default("small_group") // "small_group" | "ministry" | "committee" | "fellowship"
  description String?
  leaderId    String?
  leader      Person?  @relation("GroupLeader", fields: [leaderId], references: [id], onDelete: SetNull)
  meetingDay  String?  // "Monday", "Tuesday", etc.
  meetingTime String?  // "18:00"
  location    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  members     Person[] @relation("GroupMembers")

  @@index([churchId, type])
}

model Tag {
  id      String   @id @default(cuid())
  name    String
  people  Person[] @relation("PersonTags")
}

// ── Attendance ────────────────────────────────────────────
// A service/meeting on a given day. Holds demographic headcounts and (optionally)
// individually checked-in people via AttendanceRecord.
model AttendanceSession {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  serviceName String
  date        DateTime
  note        String?
  adults      Int      @default(0)
  teens       Int      @default(0)
  children    Int      @default(0)
  visitors    Int      @default(0)
  createdAt   DateTime @default(now())

  records AttendanceRecord[]

  @@index([churchId])
  @@index([date])
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id])
  sessionId   String?
  session     AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guestName   String?  // for unidentified / visitor self check-ins
  category    String   @default("adult") // adult | teen | child | visitor
  serviceName String
  date        DateTime
  method      String   @default("qr") // qr | manual | self

  @@index([churchId])
  @@index([date])
  @@index([sessionId])
}

// ── Giving ────────────────────────────────────────────────
enum GiftMethod {
  MTN_MoMo
  Telecel_Cash
  AirtelTigo
  Card
  Cash
}

model Fund {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  color    String   @default("#6D5EF8")
  gifts    Gift[]
  pledges  Pledge[]

  @@index([churchId])
}

model Gift {
  id            String     @id @default(cuid())
  churchId      String
  church        Church     @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?    @relation(fields: [branchId], references: [id])
  personId      String?
  person        Person?    @relation(fields: [personId], references: [id])
  donorName     String? // for gifts from non-members / visitors
  fundId        String?
  fund          Fund?      @relation(fields: [fundId], references: [id])
  amount        Decimal    @db.Decimal(12, 2)
  currency      String     @default("GHS")
  method        GiftMethod @default(Cash)
  recurring     Boolean    @default(false)
  reference     String? // Paystack reference
  receiptSent   Boolean    @default(false)
  date          DateTime   @default(now())

  @@index([churchId])
  @@index([date])
}

model Campaign {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  goal      Decimal  @db.Decimal(12, 2)
  raised    Decimal  @default(0) @db.Decimal(12, 2)
  endsAt    DateTime?
  pledges   Pledge[]

  @@index([churchId])
}

model Pledge {
  id         String    @id @default(cuid())
  churchId   String
  church     Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fundId     String?
  fund       Fund?     @relation(fields: [fundId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  donorName  String
  amount     Decimal   @db.Decimal(12, 2)
  fulfilled  Decimal   @default(0) @db.Decimal(12, 2)
  dueAt      DateTime?

  @@index([churchId])
}

// ── Events ────────────────────────────────────────────────
model Event {
  id            String         @id @default(cuid())
  churchId      String
  church        Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  title         String
  type          String?
  startsAt      DateTime
  capacity      Int?
  paid          Boolean        @default(false)
  price         Decimal?       @db.Decimal(12, 2)
  registrations Registration[]

  @@index([churchId])
}

model Registration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  checkedIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([eventId])
}

// ── Volunteers ────────────────────────────────────────────
model VolunteerAssignment {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  team      String
  role      String
  personName String
  serviceDate DateTime
  confirmed Boolean  @default(false)

  @@index([churchId])
}

// ── Communications ────────────────────────────────────────
enum Channel {
  SMS
  Email
  Push
}

model Communication {
  id         String   @id @default(cuid())
  churchId   String
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name       String
  channel    Channel
  body       String
  segment    String?
  sent       Int      @default(0)
  delivered  Int      @default(0)
  opened     Int      @default(0)
  status     String   @default("draft") // draft | scheduled | sent
  scheduledAt DateTime?
  createdAt  DateTime @default(now())

  @@index([churchId])
}

// ── Reminders & automations ───────────────────────────────
model Automation {
  id              String    @id @default(cuid())
  churchId        String
  church          Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  trigger         String    // birthday, anniversary, visitor_followup, lapsed, new_member, giving_thanks, custom
  channel         Channel   @default(SMS)
  active          Boolean   @default(true)
  runs            Int       @default(0)
  messageTemplate String?
  lastRunAt       DateTime?
  customDate      DateTime? // for custom trigger: the date to send
  customRecurrence String?  // "once" | "weekly" | "monthly" | "yearly"
  audience        String?   // "all" | "active" | "department:X" — who gets the custom reminder

  @@index([churchId])
}

model Reminder {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  type      String
  targetName String
  sendAt    DateTime
  sent      Boolean  @default(false)

  @@index([churchId])
}

// ── Harvest ──────────────────────────────────────────────
model Harvest {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  year      Int
  title     String   @default("Annual Harvest")
  date      DateTime?
  goal      Decimal? @db.Decimal(12, 2)
  raised    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  contributions HarvestContribution[]

  @@unique([churchId, year])
  @@index([churchId])
}

model HarvestContribution {
  id          String      @id @default(cuid())
  harvestId   String
  harvest     Harvest     @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  churchId    String
  church      Church      @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId    String?
  person      Person?     @relation(fields: [personId], references: [id])
  donorName   String
  donorPhone  String?
  donorType   String      @default("member") // "member" or "visitor"
  amount      Decimal     @db.Decimal(12, 2)
  method      GiftMethod  @default(Cash)
  date        DateTime    @default(now())
  receiptSent Boolean     @default(false)

  @@index([harvestId])
  @@index([churchId])
}

// ── Accounting ────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  description String
  category    String
  fund        String?
  amount      Decimal  @db.Decimal(12, 2) // positive = income, negative = expense
  date        DateTime @default(now())

  @@index([churchId])
}

// ── SMS credits ───────────────────────────────────────────
// Prepaid wallet ledger. `credits` is signed: + for top-ups/bonus, − for usage.
model SmsTransaction {
  id           String   @id @default(cuid())
  churchId     String
  church       Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  kind         String   // topup | usage | bonus | refund
  credits      Int      // signed change
  balanceAfter Int
  note         String?
  reference    String?  // Paystack reference for top-ups
  createdAt    DateTime @default(now())

  @@index([churchId])
}

// ── Phone verification (OTP) ──────────────────────────────
// Holds a one-time code sent by SMS. For signup it also stashes the pending
// account details (as JSON) so the account is created only after verification.
model PhoneVerification {
  id        String   @id @default(cuid())
  phone     String
  code      String
  purpose   String   @default("signup") // signup | login | reset-password
  payload   Json? // pending signup details (church, name, email, passwordHash)
  userId    String? // for "login" purpose: the user verifying their phone
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

// ── Platform (SuperAdmin) ─────────────────────────────────
// Editable site/marketing content, stored as JSON keyed by section. The
// marketing site reads these with a fallback to hardcoded defaults, so the app
// renders fine even before any row exists.
model SiteContent {
  key       String   @id // e.g. "hero", "testimonials", "pricing"
  value     Json
  updatedAt DateTime @updatedAt
}

// ── Welfare / benevolence ─────────────────────────────────
model WelfareRecord {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  recipientName String
  type        String   @default("financial") // "financial" | "food" | "medical" | "housing" | "education" | "other"
  amount      Decimal? @db.Decimal(12, 2)
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([churchId, date])
}

// ── Church notices (internal announcements board) ─────────
model ChurchNotice {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([churchId, createdAt])
}

// Platform-wide announcements the SuperAdmin broadcasts to all churches.
model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String
  level     String    @default("info") // info | warning | success
  active    Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

// ── Billing ───────────────────────────────────────────────
model Subscription {
  id         String   @id @default(cuid())
  churchId   String   @unique
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan       String   @default("free") // free | starter | growth | unlimited
  interval   String   @default("monthly") // monthly | yearly
  status     String   @default("active") // active | grace
  renewsAt   DateTime?
  paystackCustomerCode String?

  // SuperAdmin bypass: lets a church upgrade to bypassPlan without payment
  bypassPlan String?  // plan they can upgrade to for free
  bypassCode String?  // 6-digit code sent via SMS
}

// ── Prayer requests ───────────────────────────────────────
model PrayerRequest {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  name        String
  request     String
  isAnonymous Boolean  @default(false)
  status      String   @default("active") // "active" | "answered" | "archived"
  prayerCount Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([churchId, status])
}

// ── Follow-ups ────────────────────────────────────────────
model FollowUp {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  visitorId   String?
  visitor     Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  type        String   // "new_visitor" | "new_member" | "pastoral" | "custom"
  title       String
  note        String?
  status      String   @default("open") // "open" | "in_progress" | "done"
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([churchId, status])
}

// ── Visitors ──────────────────────────────────────────────
model Visitor {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  phone     String?
  email     String?
  purpose   String?
  notes     String?
  customFields Json?
  visitDate DateTime @default(now())
  createdAt DateTime @default(now())
  followUps FollowUp[]

  @@index([churchId, visitDate])
}

// ── Audit Log ─────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // e.g. "create", "update", "delete"
  entity    String   // e.g. "person", "gift", "event"
  entityId  String?  // ID of the affected record
  detail    String?  // human-readable summary
  meta      Json?    // extra context (old values, etc.)
  createdAt DateTime @default(now())

  @@index([churchId, createdAt])
  @@index([userId])
}

// ── Sermons & Media ───────────────────────────────────────
model Sermon {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  title       String
  preacher    String?
  series      String?
  date        DateTime @default(now())
  scripture   String?
  notes       String?  @db.Text
  audioUrl    String?
  videoUrl    String?
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([churchId, date])
}

// ── Assets / Equipment ────────────────────────────────────
model Asset {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  category    String   @default("general")
  location    String?
  condition   String   @default("good")
  serialNo    String?
  purchaseDate DateTime?
  purchasePrice Float?
  notes       String?
  createdAt   DateTime @default(now())

  @@index([churchId, category])
}

// ── Expenses ──────────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  description String
  category    String   @default("general")
  amount      Float
  vendor      String?
  receiptRef  String?
  approvedBy  String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([churchId, date])
}

// ── Facilities & Bookings ─────────────────────────────────
model Facility {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  capacity  Int?
  location  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  bookings  Booking[]

  @@index([churchId])
}

model Booking {
  id         String   @id @default(cuid())
  churchId   String
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  title      String
  bookedBy   String
  startTime  DateTime
  endTime    DateTime
  notes      String?
  status     String   @default("confirmed")
  createdAt  DateTime @default(now())

  @@index([churchId, startTime])
  @@index([facilityId, startTime])
}

// ── Devotionals ───────────────────────────────────────────
model Devotional {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  title     String
  scripture String?
  body      String   @db.Text
  author    String?
  date      DateTime @default(now())
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([churchId, date])
}

// ── Testimonies / Praise Reports ─────────────────────────
model Testimony {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId  String?
  person    Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  title     String
  body      String   @db.Text
  category  String   @default("praise") // praise, healing, provision, deliverance, salvation, other
  status    String   @default("pending") // pending, approved, featured
  anonymous Boolean  @default(false)
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([churchId, date])
  @@index([churchId, status])
}

// ── Counseling / Pastoral Care Log ───────────────────────
model CounselingSession {
  id           String   @id @default(cuid())
  churchId     String
  church       Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  personId     String?
  person       Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  counselorId  String?
  counselor    User?    @relation(fields: [counselorId], references: [id], onDelete: SetNull)
  type         String   @default("general") // general, marriage, grief, spiritual, family, addiction, other
  summary      String   @db.Text
  notes        String?  @db.Text
  status       String   @default("open") // open, follow-up, closed
  confidential Boolean  @default(true)
  date         DateTime @default(now())
  followUpDate DateTime?
  createdAt    DateTime @default(now())

  @@index([churchId, date])
  @@index([personId])
}

// ── Budget Management ────────────────────────────────────
model Budget {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  year      Int
  quarter   Int?     // null = annual, 1-4 = quarterly
  status    String   @default("draft") // draft, approved, active, closed
  total     Float    @default(0)
  notes     String?  @db.Text
  items     BudgetItem[]
  createdAt DateTime @default(now())

  @@index([churchId, year])
}

model BudgetItem {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  budgetId  String
  budget    Budget   @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  category  String
  description String
  amount    Float
  spent     Float    @default(0)
  createdAt DateTime @default(now())

  @@index([budgetId])
}

// ── Volunteer Scheduling / Roster ────────────────────────
model VolunteerRoster {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String   // e.g. "Sunday Ushering - July 2026"
  ministry  String?  // which ministry/department
  startDate DateTime
  endDate   DateTime
  notes     String?  @db.Text
  slots     VolunteerSlot[]
  createdAt DateTime @default(now())

  @@index([churchId, startDate])
}

model VolunteerSlot {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  rosterId  String
  roster    VolunteerRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  personId  String?
  person    Person?  @relation(fields: [personId], references: [id], onDelete: SetNull)
  role      String   // e.g. "Usher", "Sound tech", "Singer"
  date      DateTime
  shift     String   @default("morning") // morning, afternoon, evening, full-day
  status    String   @default("assigned") // assigned, confirmed, swapped, absent
  createdAt DateTime @default(now())

  @@index([rosterId])
  @@index([personId])
}

// ── Biometric Credentials ────────────────────────────────
// Supports BOTH:
//   "webauthn" — laptop/phone fingerprint (instant, no setup)
//   "scanner"  — USB fingerprint scanner (via local agent)
model BiometricCredential {
  id              String   @id @default(cuid())
  personId        String
  person          Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  churchId        String
  type            String   @default("webauthn") // "webauthn" or "scanner"

  // WebAuthn fields (laptop/phone fingerprint)
  credentialId    String?  @db.Text
  publicKey       String?  @db.Text
  counter         BigInt   @default(0)
  transports      String?

  // Scanner fields (USB fingerprint scanner)
  templateData    String?  @db.Text
  finger          String?
  quality         Int?
  format          String?

  deviceName      String?
  registeredAt    DateTime @default(now())

  @@index([personId])
  @@index([churchId])
  @@index([churchId, type])
}
