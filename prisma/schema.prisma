// WorshipHQ — multi-tenant church management schema.
// Every record is scoped to a Church (tenant) and optionally a Branch.
// The app currently runs in stub mode on seeded demo data (src/lib/demo/data.ts);
// this schema mirrors those shapes so wiring a real PostgreSQL database is a
// drop-in: set DATABASE_URL, run `npx prisma migrate dev`, then swap demo reads
// for Prisma queries.

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URLs live in prisma.config.ts (DATABASE_URL / DIRECT_URL),
// not in the schema. The datasource here only declares the provider.
datasource db {
  provider = "postgresql"
}

// ── Tenancy ───────────────────────────────────────────────
model Church {
  id           String   @id @default(cuid())
  name         String
  denomination String?
  city         String?
  country      String   @default("Ghana")
  address      String?
  accentColor  String   @default("#6D5EF8")
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  branches      Branch[]
  users         User[]
  people        Person[]
  households     Household[]
  groups        Group[]
  funds         Fund[]
  gifts         Gift[]
  pledges       Pledge[]
  campaigns     Campaign[]
  events        Event[]
  attendance    AttendanceRecord[]
  assignments   VolunteerAssignment[]
  communications Communication[]
  automations   Automation[]
  reminders     Reminder[]
  transactions  Transaction[]
  subscription  Subscription?
}

model Branch {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  city      String?
  isHQ      Boolean  @default(false)
  createdAt DateTime @default(now())

  people      Person[]
  events      Event[]
  attendance  AttendanceRecord[]
  gifts       Gift[]
  users       User[]

  @@index([churchId])
}

// ── Auth / RBAC ───────────────────────────────────────────
enum Role {
  Owner
  Admin
  Finance
  Leader
  Volunteer
}

model User {
  id           String   @id @default(cuid())
  churchId     String
  church       Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(Volunteer)
  // A User (logs in) may be linked to a Person (a congregant record).
  personId     String?  @unique
  person       Person?  @relation(fields: [personId], references: [id])
  createdAt    DateTime @default(now())

  @@index([churchId])
}

// ── People ────────────────────────────────────────────────
enum PersonStatus {
  active
  visitor
  inactive
}

model Person {
  id          String       @id @default(cuid())
  churchId    String
  church      Church       @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id])
  firstName   String
  lastName    String
  email       String?
  phone       String?
  status      PersonStatus @default(active)
  location    String?
  photoUrl    String?
  birthday    String? // MM-DD
  anniversary String? // MM-DD
  joinedAt    DateTime     @default(now())
  notes       String?
  customFields Json?

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])
  groups      Group[]    @relation("GroupMembers")
  tags        Tag[]      @relation("PersonTags")
  gifts       Gift[]
  attendance  AttendanceRecord[]
  user        User?

  @@index([churchId])
  @@index([branchId])
}

model Household {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  members  Person[]

  @@index([churchId])
}

model Group {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  type     String?  // ministry, small group, etc.
  members  Person[] @relation("GroupMembers")

  @@index([churchId])
}

model Tag {
  id      String   @id @default(cuid())
  name    String
  people  Person[] @relation("PersonTags")
}

// ── Attendance ────────────────────────────────────────────
model AttendanceRecord {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id])
  serviceName String
  date        DateTime
  method      String   @default("qr") // qr | manual | self

  @@index([churchId])
  @@index([date])
}

// ── Giving ────────────────────────────────────────────────
enum GiftMethod {
  MTN_MoMo
  Telecel_Cash
  AirtelTigo
  Card
  Cash
}

model Fund {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  color    String   @default("#6D5EF8")
  gifts    Gift[]
  pledges  Pledge[]

  @@index([churchId])
}

model Gift {
  id            String     @id @default(cuid())
  churchId      String
  church        Church     @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?    @relation(fields: [branchId], references: [id])
  personId      String?
  person        Person?    @relation(fields: [personId], references: [id])
  fundId        String?
  fund          Fund?      @relation(fields: [fundId], references: [id])
  amount        Decimal    @db.Decimal(12, 2)
  currency      String     @default("GHS")
  method        GiftMethod @default(Cash)
  recurring     Boolean    @default(false)
  reference     String? // Paystack reference
  receiptSent   Boolean    @default(false)
  date          DateTime   @default(now())

  @@index([churchId])
  @@index([date])
}

model Campaign {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  goal      Decimal  @db.Decimal(12, 2)
  raised    Decimal  @default(0) @db.Decimal(12, 2)
  endsAt    DateTime?
  pledges   Pledge[]

  @@index([churchId])
}

model Pledge {
  id         String    @id @default(cuid())
  churchId   String
  church     Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fundId     String?
  fund       Fund?     @relation(fields: [fundId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  donorName  String
  amount     Decimal   @db.Decimal(12, 2)
  fulfilled  Decimal   @default(0) @db.Decimal(12, 2)
  dueAt      DateTime?

  @@index([churchId])
}

// ── Events ────────────────────────────────────────────────
model Event {
  id            String         @id @default(cuid())
  churchId      String
  church        Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  title         String
  type          String?
  startsAt      DateTime
  capacity      Int?
  paid          Boolean        @default(false)
  price         Decimal?       @db.Decimal(12, 2)
  registrations Registration[]

  @@index([churchId])
}

model Registration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  checkedIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([eventId])
}

// ── Volunteers ────────────────────────────────────────────
model VolunteerAssignment {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  team      String
  role      String
  personName String
  serviceDate DateTime
  confirmed Boolean  @default(false)

  @@index([churchId])
}

// ── Communications ────────────────────────────────────────
enum Channel {
  SMS
  Email
  Push
}

model Communication {
  id         String   @id @default(cuid())
  churchId   String
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name       String
  channel    Channel
  body       String
  segment    String?
  sent       Int      @default(0)
  delivered  Int      @default(0)
  opened     Int      @default(0)
  status     String   @default("draft") // draft | scheduled | sent
  scheduledAt DateTime?
  createdAt  DateTime @default(now())

  @@index([churchId])
}

// ── Reminders & automations ───────────────────────────────
model Automation {
  id          String  @id @default(cuid())
  churchId    String
  church      Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     String  // e.g. "birthday", "anniversary", "visitor_followup", "lapsed"
  channel     Channel @default(SMS)
  active      Boolean @default(true)
  runs        Int     @default(0)

  @@index([churchId])
}

model Reminder {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  type      String
  targetName String
  sendAt    DateTime
  sent      Boolean  @default(false)

  @@index([churchId])
}

// ── Accounting ────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  description String
  category    String
  fund        String?
  amount      Decimal  @db.Decimal(12, 2) // positive = income, negative = expense
  date        DateTime @default(now())

  @@index([churchId])
}

// ── Billing ───────────────────────────────────────────────
model Subscription {
  id         String   @id @default(cuid())
  churchId   String   @unique
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan       String   @default("free") // free | starter | growth | unlimited
  interval   String   @default("monthly") // monthly | yearly
  status     String   @default("active")
  renewsAt   DateTime?
  paystackCustomerCode String?
}
