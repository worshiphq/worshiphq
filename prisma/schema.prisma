// WorshipHQ — multi-tenant church management schema.
// Every record is scoped to a Church (tenant) and optionally a Branch.
// The app currently runs in stub mode on seeded demo data (src/lib/demo/data.ts);
// this schema mirrors those shapes so wiring a real PostgreSQL database is a
// drop-in: set DATABASE_URL, run `npx prisma migrate dev`, then swap demo reads
// for Prisma queries.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Tenancy ───────────────────────────────────────────────
model Church {
  id           String   @id @default(cuid())
  slug         String   @unique
  isDemo       Boolean  @default(false)
  suspended    Boolean  @default(false)
  name         String
  denomination String?
  city         String?
  country      String   @default("Ghana")
  address      String?
  accentColor  String   @default("#6D5EF8")
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // JSON config: which fields to show on the public join form
  // e.g. { "occupation": true, "dateOfBirth": true, "nationality": false, ... }
  registrationFields Json?

  branches      Branch[]
  users         User[]
  people        Person[]
  departments   Department[]
  households     Household[]
  groups        Group[]
  funds         Fund[]
  gifts         Gift[]
  pledges       Pledge[]
  campaigns     Campaign[]
  events        Event[]
  attendance    AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  assignments   VolunteerAssignment[]
  communications Communication[]
  automations   Automation[]
  reminders     Reminder[]
  transactions  Transaction[]
  subscription  Subscription?
}

model Branch {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  city      String?
  isHQ      Boolean  @default(false)
  createdAt DateTime @default(now())

  people      Person[]
  events      Event[]
  attendance  AttendanceRecord[]
  attendanceSessions AttendanceSession[]
  gifts       Gift[]
  users       User[]

  @@index([churchId])
}

// ── Auth / RBAC ───────────────────────────────────────────
enum Role {
  Owner
  Admin
  Pastor
  Finance
  Media
  Leader
  Volunteer
}

// ── Departments ──────────────────────────────────────────
model Department {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())

  people Person[]

  @@unique([churchId, name])
  @@index([churchId])
}

model User {
  id           String   @id @default(cuid())
  churchId     String
  church       Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId     String?
  branch       Branch?  @relation(fields: [branchId], references: [id])
  email        String   @unique
  name         String
  passwordHash String?
  role         Role     @default(Volunteer)
  // A User (logs in) may be linked to a Person (a congregant record).
  personId     String?  @unique
  person       Person?  @relation(fields: [personId], references: [id])
  createdAt    DateTime @default(now())

  @@index([churchId])
}

// ── People ────────────────────────────────────────────────
enum PersonStatus {
  active
  visitor
  inactive
}

model Person {
  id          String       @id @default(cuid())
  churchId    String
  church      Church       @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?      @relation(fields: [branchId], references: [id])
  firstName   String
  lastName    String
  otherNames  String?
  email       String?
  phone       String?
  status      PersonStatus @default(active)
  location    String?
  photoUrl    String?
  birthday    String? // MM-DD
  anniversary String? // MM-DD
  joinedAt    DateTime     @default(now())
  notes       String?
  customFields Json?

  // ── Rich profile fields (from registration / admin entry) ──
  gender         String?   // Male, Female
  title          String?   // e.g. Rev., Deaconess, Elder
  dateOfBirth    DateTime? // full DOB
  occupation     String?
  employer       String?
  previousChurch String?
  dateOfMembership DateTime?
  placeOfBirth   String?
  nationality    String?  @default("Ghanaian")
  country        String?  @default("Ghana")
  region         String?
  district       String?
  town           String?
  nationalId     String?
  houseAddress   String?
  homeTown       String?
  workPhone      String?
  postalAddress  String?
  homePhone      String?
  specialInterest String?
  maritalStatus  String?  // Single, Married, Divorced, Widowed
  baptized       Boolean? // Has been baptised?

  // ── Emergency contact ──
  emergencyName    String?
  emergencyPhone   String?
  emergencyRelation String?
  emergencyEmail   String?
  emergencyAddress String?

  // ── Department ──
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  householdId String?
  household   Household? @relation(fields: [householdId], references: [id])
  groups      Group[]    @relation("GroupMembers")
  tags        Tag[]      @relation("PersonTags")
  gifts       Gift[]
  attendance  AttendanceRecord[]
  user        User?

  @@index([churchId])
  @@index([branchId])
  @@index([departmentId])
}

model Household {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  members  Person[]

  @@index([churchId])
}

model Group {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  type     String?  // ministry, small group, etc.
  members  Person[] @relation("GroupMembers")

  @@index([churchId])
}

model Tag {
  id      String   @id @default(cuid())
  name    String
  people  Person[] @relation("PersonTags")
}

// ── Attendance ────────────────────────────────────────────
// A service/meeting on a given day. Holds demographic headcounts and (optionally)
// individually checked-in people via AttendanceRecord.
model AttendanceSession {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  serviceName String
  date        DateTime
  note        String?
  adults      Int      @default(0)
  teens       Int      @default(0)
  children    Int      @default(0)
  visitors    Int      @default(0)
  createdAt   DateTime @default(now())

  records AttendanceRecord[]

  @@index([churchId])
  @@index([date])
}

model AttendanceRecord {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId    String?
  branch      Branch?  @relation(fields: [branchId], references: [id])
  personId    String?
  person      Person?  @relation(fields: [personId], references: [id])
  sessionId   String?
  session     AttendanceSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  guestName   String?  // for unidentified / visitor self check-ins
  category    String   @default("adult") // adult | teen | child | visitor
  serviceName String
  date        DateTime
  method      String   @default("qr") // qr | manual | self

  @@index([churchId])
  @@index([date])
  @@index([sessionId])
}

// ── Giving ────────────────────────────────────────────────
enum GiftMethod {
  MTN_MoMo
  Telecel_Cash
  AirtelTigo
  Card
  Cash
}

model Fund {
  id       String   @id @default(cuid())
  churchId String
  church   Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name     String
  color    String   @default("#6D5EF8")
  gifts    Gift[]
  pledges  Pledge[]

  @@index([churchId])
}

model Gift {
  id            String     @id @default(cuid())
  churchId      String
  church        Church     @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?    @relation(fields: [branchId], references: [id])
  personId      String?
  person        Person?    @relation(fields: [personId], references: [id])
  donorName     String? // for gifts from non-members / visitors
  fundId        String?
  fund          Fund?      @relation(fields: [fundId], references: [id])
  amount        Decimal    @db.Decimal(12, 2)
  currency      String     @default("GHS")
  method        GiftMethod @default(Cash)
  recurring     Boolean    @default(false)
  reference     String? // Paystack reference
  receiptSent   Boolean    @default(false)
  date          DateTime   @default(now())

  @@index([churchId])
  @@index([date])
}

model Campaign {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name      String
  goal      Decimal  @db.Decimal(12, 2)
  raised    Decimal  @default(0) @db.Decimal(12, 2)
  endsAt    DateTime?
  pledges   Pledge[]

  @@index([churchId])
}

model Pledge {
  id         String    @id @default(cuid())
  churchId   String
  church     Church    @relation(fields: [churchId], references: [id], onDelete: Cascade)
  fundId     String?
  fund       Fund?     @relation(fields: [fundId], references: [id])
  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  donorName  String
  amount     Decimal   @db.Decimal(12, 2)
  fulfilled  Decimal   @default(0) @db.Decimal(12, 2)
  dueAt      DateTime?

  @@index([churchId])
}

// ── Events ────────────────────────────────────────────────
model Event {
  id            String         @id @default(cuid())
  churchId      String
  church        Church         @relation(fields: [churchId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?        @relation(fields: [branchId], references: [id])
  title         String
  type          String?
  startsAt      DateTime
  capacity      Int?
  paid          Boolean        @default(false)
  price         Decimal?       @db.Decimal(12, 2)
  registrations Registration[]

  @@index([churchId])
}

model Registration {
  id          String   @id @default(cuid())
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name        String
  email       String?
  phone       String?
  checkedIn   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([eventId])
}

// ── Volunteers ────────────────────────────────────────────
model VolunteerAssignment {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  team      String
  role      String
  personName String
  serviceDate DateTime
  confirmed Boolean  @default(false)

  @@index([churchId])
}

// ── Communications ────────────────────────────────────────
enum Channel {
  SMS
  Email
  Push
}

model Communication {
  id         String   @id @default(cuid())
  churchId   String
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name       String
  channel    Channel
  body       String
  segment    String?
  sent       Int      @default(0)
  delivered  Int      @default(0)
  opened     Int      @default(0)
  status     String   @default("draft") // draft | scheduled | sent
  scheduledAt DateTime?
  createdAt  DateTime @default(now())

  @@index([churchId])
}

// ── Reminders & automations ───────────────────────────────
model Automation {
  id          String  @id @default(cuid())
  churchId    String
  church      Church  @relation(fields: [churchId], references: [id], onDelete: Cascade)
  name        String
  description String?
  trigger     String  // e.g. "birthday", "anniversary", "visitor_followup", "lapsed"
  channel     Channel @default(SMS)
  active      Boolean @default(true)
  runs        Int     @default(0)

  @@index([churchId])
}

model Reminder {
  id        String   @id @default(cuid())
  churchId  String
  church    Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  type      String
  targetName String
  sendAt    DateTime
  sent      Boolean  @default(false)

  @@index([churchId])
}

// ── Accounting ────────────────────────────────────────────
model Transaction {
  id          String   @id @default(cuid())
  churchId    String
  church      Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  description String
  category    String
  fund        String?
  amount      Decimal  @db.Decimal(12, 2) // positive = income, negative = expense
  date        DateTime @default(now())

  @@index([churchId])
}

// ── Platform (SuperAdmin) ─────────────────────────────────
// Editable site/marketing content, stored as JSON keyed by section. The
// marketing site reads these with a fallback to hardcoded defaults, so the app
// renders fine even before any row exists.
model SiteContent {
  key       String   @id // e.g. "hero", "testimonials", "pricing"
  value     Json
  updatedAt DateTime @updatedAt
}

// Platform-wide announcements the SuperAdmin broadcasts to all churches.
model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String
  level     String    @default("info") // info | warning | success
  active    Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

// ── Billing ───────────────────────────────────────────────
model Subscription {
  id         String   @id @default(cuid())
  churchId   String   @unique
  church     Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  plan       String   @default("free") // free | starter | growth | unlimited
  interval   String   @default("monthly") // monthly | yearly
  status     String   @default("active")
  renewsAt   DateTime?
  paystackCustomerCode String?
}
