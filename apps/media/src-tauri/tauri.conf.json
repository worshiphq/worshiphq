{
  "$schema": "https://raw.githubusercontent.com/nicokosi/tauri-v2-schema/main/config.schema.json",
  "productName": "WorshipHQ Media",
  "version": "0.1.0",
  "identifier": "com.worshiphq.media",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "resources": {
      "resources/bibles/*.db": "bibles/"
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "WorshipHQ Media",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "open": true,
      "save": false
    }
  }
}
