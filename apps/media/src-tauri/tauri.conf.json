{
  "$schema": "https://raw.githubusercontent.com/nicokosi/tauri-v2-schema/main/config.schema.json",
  "productName": "WorshipHQ Media",
  "version": "0.1.0",
  "identifier": "com.worshiphq.media",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/bibles/*.db": "bibles/"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "languages": ["English"],
        "installMode": "currentUser"
      }
    },
    "shortDescription": "Church Presentation Software",
    "longDescription": "WorshipHQ Media — Professional church presentation software for worship services. Project scripture, songs, and media to screens.",
    "copyright": "© 2025 WorshipHQ",
    "category": "Utility"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "WorshipHQ Media",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {
      "open": true,
      "save": false
    }
  }
}
