# ════════════════════════════════════════════════════════════════════
#  WorshipHQ — environment variables
#  Copy this file to `.env.local` and fill in the keys you have.
#  The app runs fully with ZERO real keys: any integration without a key
#  falls back to a safe demo/stub mode. Only fill what you need.
# ════════════════════════════════════════════════════════════════════

# ── APP ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="WorshipHQ"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── DATABASE (PostgreSQL — e.g. Supabase, Neon, Railway) ─
# Leave blank to run in stub mode with seeded demo data.
DATABASE_URL="postgresql://user:password@localhost:5432/worshiphq?schema=public"
DIRECT_URL=""   # optional unpooled connection for migrations

# ── AUTH (Auth.js / NextAuth) ──────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""              # generate: openssl rand -base64 32
GOOGLE_CLIENT_ID=""            # optional Google sign-in
GOOGLE_CLIENT_SECRET=""

# ── PAYMENTS — Paystack (Ghana: Mobile Money + cards, GHS)
PAYSTACK_SECRET_KEY="sk_test_xxxxx"
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY="pk_test_xxxxx"
PAYSTACK_WEBHOOK_SECRET=""
PAYSTACK_CALLBACK_URL="http://localhost:3000/api/payments/callback"

# ── SMS (Ghana providers — set SMS_PROVIDER, fill that one)
SMS_PROVIDER="arkesel"         # arkesel | hubtel | mnotify | twilio
ARKESEL_API_KEY=""             # Arkesel (Ghana)
ARKESEL_SENDER_ID="WorshipHQ"
HUBTEL_CLIENT_ID=""            # Hubtel (Ghana)
HUBTEL_CLIENT_SECRET=""
HUBTEL_SENDER_ID="WorshipHQ"
MNOTIFY_API_KEY=""             # mNotify (Ghana)
MNOTIFY_SENDER_ID="WorshipHQ"
TWILIO_ACCOUNT_SID=""          # Twilio (international fallback)
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ── EMAIL (set EMAIL_PROVIDER, fill that one) ──────────
EMAIL_PROVIDER="resend"        # resend | sendgrid | smtp
EMAIL_FROM="no-reply@worshiphq.org"
RESEND_API_KEY=""
SENDGRID_API_KEY=""
SMTP_HOST=""                   # generic SMTP fallback
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ── PUSH NOTIFICATIONS (PWA Web Push via VAPID) ────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""   # generate: npx web-push generate-vapid-keys
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@worshiphq.org"

# Optional Firebase Cloud Messaging (native-style mobile push)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""

# ── FILE & IMAGE STORAGE (set STORAGE_PROVIDER) ────────
STORAGE_PROVIDER="cloudinary"  # cloudinary | s3 | uploadthing
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
AWS_ACCESS_KEY_ID=""           # AWS S3 / Cloudflare R2 / compatible
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"
S3_BUCKET=""
S3_ENDPOINT=""                 # set for R2/MinIO; leave blank for AWS
UPLOADTHING_TOKEN=""

# ── MAPS (People map feature) ──────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_MAPBOX_TOKEN=""    # alternative to Google Maps

# ── CACHE / QUEUES / RATE LIMIT (Redis) ────────────────
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""      # serverless alternative
UPSTASH_REDIS_REST_TOKEN=""

# ── SCHEDULED JOBS (birthday reminders, statements, sync)
CRON_SECRET=""                 # generate: openssl rand -base64 32

# ── AI (optional — Care Copilot, sermon tools, smart lists)
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ── STOCK IMAGES (marketing site — optional) ───────────
UNSPLASH_ACCESS_KEY=""

# ── MONITORING / ANALYTICS (optional) ──────────────────
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
